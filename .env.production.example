# Copier vers .env sur le VPS et remplir SESSION_SECRET

# Domaine public de l'application
DOMAIN=mania.sn

# Base de données SQLite (chemin dans le volume Docker — ne pas changer)
DATABASE_URL=file:/data/prod.db

# Secret JWT — générer avec : openssl rand -base64 64
SESSION_SECRET=remplacer-par-une-chaine-aleatoire-de-64-caracteres-minimum

NODE_ENV=production
