# Copier ce fichier vers .env sur le VPS et remplir les valeurs

# Base de données SQLite (chemin absolu dans le volume Docker)
DATABASE_URL=file:/data/prod.db

# Secret JWT — générer avec : openssl rand -base64 64
SESSION_SECRET=remplacer-par-une-chaine-aleatoire-de-64-caracteres-minimum

# URL publique de l'application (sans slash final)
NEXTAUTH_URL=https://votre-domaine.com

NODE_ENV=production
