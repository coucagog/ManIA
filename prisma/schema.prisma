generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  name              String
  initials          String    @default("??")
  password          String
  role              String    @default("learner")
  twoFactorCode     String?
  twoFactorExpires  DateTime?
  createdAt         DateTime  @default(now())
  progress          Progress[]
  notes             Note[]
}

model Course {
  id          String     @id @default(cuid())
  slug        String     @unique
  title       String
  speaker     String
  parcours    String
  format      String
  duration    Int
  level       String
  thumbClass  String     @default("t1")
  createdAt   DateTime   @default(now())
  chapters    Chapter[]
  progress    Progress[]
}

model Chapter {
  id        String   @id @default(cuid())
  courseId  String
  title     String
  duration  Int
  format    String
  order     Int
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  notes     Note[]
}

model Progress {
  id            String   @id @default(cuid())
  userId        String
  courseId      String
  percentage    Int      @default(0)
  lastChapterId String?
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course        Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

model Note {
  id        String   @id @default(cuid())
  userId    String
  chapterId String
  content   String
  timecode  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  chapter   Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
}

model Session {
  id          String   @id @default(cuid())
  title       String
  date        DateTime
  endDate     DateTime?
  location    String
  address     String?
  description String?
  instructor  String
  maxSeats    Int?
  status      String   @default("upcoming")  // upcoming | past | cancelled
  createdAt   DateTime @default(now())
}

model Expert {
  id          String   @id @default(cuid())
  name        String
  title       String
  institution String?
  bio         String?
  photoUrl    String?
  speakerKey  String?  // matches Course.speaker for auto-linking
  order       Int      @default(0)
  createdAt   DateTime @default(now())
}
